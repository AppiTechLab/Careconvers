# Gemini API Key (required for CareConvers intent classification)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional, for alternative AI backend)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration (if using Supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Frontend API URL
VITE_API_URL=http://localhost:3000/api

# Google Text-to-Speech API Key (required for TalkingHead avatar TTS)
VITE_TTS_API_KEY=your_google_tts_api_key_here

# Environment
NODE_ENV=development

# Port
PORT=3000
